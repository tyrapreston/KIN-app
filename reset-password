<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password — KIN</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, sans-serif;
      background: #1E1A17;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .card {
      background: #2a2119;
      border-radius: 20px;
      padding: 32px 24px;
      width: 100%;
      max-width: 400px;
      border: 1px solid rgba(245,240,232,0.08);
    }
    .logo {
      font-size: 32px;
      font-weight: 900;
      color: #E8825A;
      margin-bottom: 8px;
      letter-spacing: -1px;
    }
    .logo span { color: #F5F0E8; }
    h1 {
      font-size: 22px;
      color: #F5F0E8;
      margin-bottom: 8px;
      font-weight: 700;
    }
    p {
      font-size: 14px;
      color: #9A8478;
      margin-bottom: 24px;
      line-height: 1.6;
    }
    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #9A8478;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      background: rgba(245,240,232,0.06);
      border: 1px solid rgba(245,240,232,0.12);
      border-radius: 12px;
      padding: 14px 16px;
      font-size: 15px;
      color: #F5F0E8;
      margin-bottom: 16px;
      outline: none;
    }
    input:focus { border-color: #C4622D; }
    button {
      width: 100%;
      background: #C4622D;
      color: white;
      border: none;
      border-radius: 12px;
      padding: 15px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 4px;
    }
    button:hover { background: #E8825A; }
    button:disabled { opacity: 0.6; cursor: not-allowed; }
    .message {
      margin-top: 16px;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 14px;
      display: none;
    }
    .message.success {
      background: rgba(109,191,126,0.15);
      border: 1px solid rgba(109,191,126,0.3);
      color: #6dbf7e;
      display: block;
    }
    .message.error {
      background: rgba(229,57,53,0.12);
      border: 1px solid rgba(229,57,53,0.25);
      color: #ef5350;
      display: block;
    }
    .open-app-btn {
      display: none;
      width: 100%;
      background: transparent;
      color: #E8825A;
      border: 1.5px solid rgba(196,98,45,0.4);
      border-radius: 12px;
      padding: 14px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 12px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">KIN<span>.</span></div>
    <h1>Reset your password</h1>
    <p>Enter your new password below. Once saved, go back to KIN and sign in.</p>

    <div id="form-section">
      <label>New Password</label>
      <input type="password" id="password" placeholder="At least 8 characters" />
      <label>Confirm Password</label>
      <input type="password" id="confirm" placeholder="Confirm your new password" />
      <button id="submit-btn" onclick="resetPassword()">Save New Password</button>
    </div>

    <div class="message" id="message"></div>
    <button class="open-app-btn" id="open-app" onclick="openApp()">← Open KIN App</button>
  </div>

  <script>
    const SUPABASE_URL = 'https://qhygthzvtlhhaluzmsjt.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFoeWd0aHp2dGxoaGFsdXptc2p0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1MTEwODUsImV4cCI6MjA5MTA4NzA4NX0.4sU_3lIxkP1qgMlKD1Ju7aLoLoOgp8H46nNhttKZovM';

    const { createClient } = supabase;
    const client = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    async function resetPassword() {
      const password = document.getElementById('password').value;
      const confirm = document.getElementById('confirm').value;
      const btn = document.getElementById('submit-btn');
      const msg = document.getElementById('message');

      msg.className = 'message';
      msg.style.display = 'none';

      if (!password || password.length < 8) {
        msg.textContent = 'Password must be at least 8 characters.';
        msg.className = 'message error';
        return;
      }

      if (password !== confirm) {
        msg.textContent = 'Passwords do not match.';
        msg.className = 'message error';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Saving...';

      const { error } = await client.auth.updateUser({ password });

      if (error) {
        msg.textContent = error.message || 'Something went wrong. Please try again.';
        msg.className = 'message error';
        btn.disabled = false;
        btn.textContent = 'Save New Password';
      } else {
        msg.textContent = '✓ Password updated! You can now sign in to KIN.';
        msg.className = 'message success';
        document.getElementById('form-section').style.display = 'none';
        document.getElementById('open-app').style.display = 'block';
      }
    }

    function openApp() {
      window.location.href = 'kin://';
    }
  </script>
</body>
</html>
